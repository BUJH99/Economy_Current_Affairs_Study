<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>주식 및 경제 아카데미 - 통합 플랫폼</title>
    <script src="https://unpkg.com/vue@3/dist/vue.global.js"></script>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Noto+Color+Emoji&display=swap">
    <style>

        /* * DESIGN TOKENS (Apple + Toss Inspired)
         * Minimalist, High Contrast, Airy Whitespace
         */
        :root {
            /* Colors */
            --bg-body: #ffffff;
            --bg-sidebar: #f9f9f9;
            --bg-card: #ffffff;
            --bg-card-hover: #fafafa;
            --bg-accent-subtle: #f2f4f6;
            
            --text-primary: #191f28;  /* Deep dark gray */
            --text-secondary: #4e5968; /* Medium gray */
            --text-tertiary: #8b95a1; /* Light gray */
            
            --color-blue: #3182f6;    /* Toss Blue */
            --color-red: #e15241;     /* Negative/Warm */
            --color-green: #30d158;   /* Positive/Cool */
            --color-indigo: #5856d6;
            
            --border-light: #e5e8eb;
            
            /* Spacing & Layout */
            --space-unit: 4px;
            --container-max: 1000px;
            --sidebar-width: 260px;
            
            /* Radius & Shadows */
            --radius-sm: 8px;
            --radius-md: 16px;
            --radius-lg: 24px;
            --shadow-card: 0 4px 20px rgba(0, 0, 0, 0.04);
            --shadow-float: 0 10px 40px rgba(0, 0, 0, 0.08);

            /* Typography */
            --font-stack: -apple-system, BlinkMacSystemFont, "Apple SD Gothic Neo", "Pretendard", "Malgun Gothic", sans-serif;
            --font-mono: "SF Mono", "Menlo", "Monaco", "Courier New", monospace;
            --font-emoji: "Noto Color Emoji", "Apple Color Emoji", "Segoe UI Emoji";
        }

        /* RESET */
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            font-family: var(--font-stack);
            color: var(--text-primary);
            background: var(--bg-body);
            line-height: 1.6;
            -webkit-font-smoothing: antialiased;
        }
        a { text-decoration: none; color: inherit; }
        ul { list-style: none; }

        /* LAYOUT */
        .app-container {
            display: flex;
            min-height: 100vh;
        }

        /* SIDEBAR (TOC) */
        .sidebar {
            width: var(--sidebar-width);
            background: var(--bg-sidebar);
            border-right: 1px solid var(--border-light);
            height: 100vh;
            position: sticky;
            top: 0;
            overflow-y: auto;
            padding: 2rem 1.5rem;
            display: flex;
            flex-direction: column;
            z-index: 100;
        }
        .sidebar-title {
            font-size: 1.2rem;
            font-weight: 700;
            margin-bottom: 2rem;
            color: var(--text-primary);
            letter-spacing: -0.5px;
        }
        .toc-list { display: flex; flex-direction: column; gap: 0.5rem; }
        .toc-item a {
            display: block;
            padding: 0.6rem 0.8rem;
            border-radius: var(--radius-sm);
            font-size: 0.9rem;
            color: var(--text-secondary);
            transition: all 0.2s;
        }
        .toc-item a:hover { background: rgba(0,0,0,0.03); color: var(--text-primary); }
        .toc-item a.active {
            background: #e8f3ff;
            color: var(--color-blue);
            font-weight: 600;
        }
        .toc-sub { margin-left: 1rem; font-size: 0.85rem; border-left: 2px solid var(--border-light); }

        /* MAIN CONTENT */
        .main-content {
            flex: 1;
            padding: 4rem 3rem;
            max-width: var(--container-max);
            margin: 0 auto;
        }

        /* FORECAST CHARTS */
        .chart-container-bar { flex: 1; display: flex; flex-direction: column; gap: 12px; justify-content: center; margin-top: 1.5rem; }
        .bar-row { display: flex; align-items: center; height: 35px; position: relative; }
        .bar-label { width: 100px; text-align: right; padding-right: 15px; font-weight: 600; color: var(--text-primary); font-size: 0.95rem; }
        .track { flex: 1; background: #f1f5f9; height: 100%; border-radius: 8px; overflow: visible; position: relative; }
        .fill { height: 100%; display: flex; align-items: center; justify-content: flex-end; padding-right: 10px; color: white; font-size: 0.85rem; font-weight: 700; border-radius: 8px; width: 0; transition: width 1s ease-out; }
        
        .c-tech { background: #64748b; }
        .c-samsung { background: #3b82f6; opacity: 0.8; }
        .c-hynix { background: linear-gradient(90deg, #f43f5e, #be185d); box-shadow: 0 4px 10px rgba(225, 29, 72, 0.3); position: relative; z-index: 2; }
        .c-samsung-boom { background: linear-gradient(90deg, #3b82f6, #1d4ed8); box-shadow: 0 4px 15px rgba(37, 99, 235, 0.4); position: relative; z-index: 2; }
        .c-samsung-gold { background: linear-gradient(90deg, #3b82f6, #1e3a8a); box-shadow: 0 4px 15px rgba(37, 99, 235, 0.5); position: relative; z-index: 2; border: 2px solid #fbbf24; }
        
        .winner-badge { position: absolute; z-index: 10; right: -70px; background: #fdf2f8; color: #be185d; padding: 2px 8px; border-radius: 12px; font-size: 0.75rem; font-weight: 800; border: 1px solid #fbcfe8; }
        .jump-badge { position: absolute; top: -15px; right: -60px; background: #eff6ff; color: #2563eb; border: 1px solid #bfdbfe; padding: 2px 8px; border-radius: 12px; font-size: 0.75rem; font-weight: 800; animation: bounceBounce 2s infinite; }
        .crown-icon { position: absolute; right: -30px; top: -10px; font-size: 1.2rem; filter: drop-shadow(0 2px 4px rgba(0, 0, 0, 0.2)); animation: floatFloat 3s infinite ease-in-out; }
        
        @keyframes bounceBounce { 0%, 20%, 50%, 80%, 100% { transform: translateY(0); } 40% { transform: translateY(-5px); } 60% { transform: translateY(-3px); } }
        @keyframes floatFloat { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-5px); } }

        .fc-insight-box { margin-top: 2rem; padding: 1.2rem 1.5rem; border-radius: var(--radius-md); display: flex; flex-direction: column; gap: 0.5rem; }

        /* TYPOGRAPHY */
        h1 { font-size: 2.8rem; font-weight: 800; letter-spacing: -1px; margin-bottom: 3rem; line-height: 1.2; }
        h2 { font-size: 1.8rem; font-weight: 700; margin: 4rem 0 1.5rem; padding-bottom: 1rem; border-bottom: 1px solid var(--border-light); letter-spacing: -0.5px; }
        h3 { font-size: 1.4rem; font-weight: 600; margin: 2.5rem 0 1rem; color: var(--text-primary); }
        p { margin-bottom: 1.2rem; color: var(--text-secondary); font-size: 1.05rem; word-break: keep-all; }
        strong { color: var(--text-primary); font-weight: 700; }

        /* COMPONENT: CARDS */
        .card {
            background: var(--bg-card);
            border: 1px solid var(--border-light);
            border-radius: var(--radius-md);
            padding: 1.5rem;
            margin-bottom: 1.5rem;
            box-shadow: var(--shadow-card);
            transition: transform 0.2s;
        }
        .card:hover { transform: translateY(-2px); box-shadow: var(--shadow-float); }
        
        /* COMPONENT: METRIC GRID */
        .metric-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 1.5rem;
            margin: 1.5rem 0;
        }
        .metric-card {
            background: var(--bg-accent-subtle);
            padding: 1.5rem;
            border-radius: var(--radius-md);
            display: flex;
            flex-direction: column;
        }
        .metric-label { font-size: 0.9rem; color: var(--text-tertiary); font-weight: 600; text-transform: uppercase; margin-bottom: 0.5rem; }
        .metric-value { font-size: 1.8rem; font-weight: 800; color: var(--text-primary); margin-bottom: 0.5rem; }
        .metric-desc { font-size: 0.9rem; color: var(--text-secondary); line-height: 1.4; }

        /* COMPONENT: COMPARISON TABLE */
        .comp-table-container { overflow-x: auto; margin: 1.5rem 0; border-radius: var(--radius-md); border: 1px solid var(--border-light); }
        .comp-table { width: 100%; border-collapse: collapse; min-width: 600px; }
        .comp-table th, .comp-table td { padding: 1rem 1.5rem; text-align: left; border-bottom: 1px solid var(--border-light); }
        .comp-table th { background: #fafafa; font-weight: 600; color: var(--text-secondary); font-size: 0.9rem; }
        .comp-table td { font-size: 0.95rem; }
        .comp-table tr:last-child td { border-bottom: none; }
        .num-cell { text-align: right; font-family: var(--font-mono); font-weight: 600; }
        #p4-gdp .comp-table-container { overflow-x: visible; }
        #p4-gdp .comp-table { width: 100%; min-width: 0; table-layout: fixed; }
        #p4-gdp .comp-table th, #p4-gdp .comp-table td { padding-left: 1rem; padding-right: 1rem; }
        #p4-gdp .comp-table th:nth-child(2),
        #p4-gdp .comp-table td:nth-child(2),
        #p4-gdp .comp-table th:nth-child(6),
        #p4-gdp .comp-table td:nth-child(6) { white-space: nowrap; }
        #p4-gdp .num-cell { font-family: var(--font-stack); font-weight: 600; font-variant-numeric: tabular-nums; }
        #p4-gdp .num-cell.heat-cell { background-clip: padding-box; transition: background-image 0.2s ease; }
        #p4-gdp .comp-table tbody td:nth-child(3) { font-family: var(--font-emoji), var(--font-stack); }
        @media (min-width: 1200px) {
            #p4-gdp .comp-table-container { width: calc(100% + 64px); margin-left: -32px; }
        }

        /* COMPONENT: FORMULA BOX */
        .formula-box {
            background: #fff;
            border: 1px dashed var(--border-light);
            border-radius: var(--radius-sm);
            padding: 1.2rem;
            margin: 1rem 0;
            text-align: center;
            font-family: var(--font-mono);
            font-size: 1.1rem;
            color: var(--color-indigo);
            background-color: #f8f8fc;
        }

        /* COMPONENT: BADGES */
        .badge {
            display: inline-flex;
            align-items: center;
            padding: 2px 8px;
            border-radius: 4px;
            font-size: 0.8rem;
            font-weight: 600;
            margin-left: 6px;
        }
        .badge-up { background: rgba(229, 78, 65, 0.1); color: var(--color-red); }
        .badge-down { background: rgba(49, 130, 246, 0.1); color: var(--color-blue); }
        .badge-neu { background: rgba(139, 149, 161, 0.1); color: var(--text-secondary); }

        /* COMPONENT: CALLOUT */
        .callout {
            background: #f0f7ff;
            border-left: 4px solid var(--color-blue);
            padding: 1.5rem;
            border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
            margin: 2rem 0;
        }
        .callout h4 { margin: 0 0 0.5rem; color: var(--color-blue); font-size: 1.1rem; display: flex; align-items: center; gap: 8px; }

        /* COMPONENT: ACCORDION ($$심화$$) */
        details.accordion {
            background: #ffffff;
            border: 1px solid var(--border-light);
            border-radius: var(--radius-md);
            margin: 1.5rem 0;
            overflow: hidden;
            transition: all 0.3s ease;
        }
        details.accordion summary {
            padding: 1.2rem 1.5rem;
            font-weight: 600;
            cursor: pointer;
            list-style: none;
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: #fafafa;
        }
        details.accordion summary::-webkit-details-marker { display: none; }
        details.accordion summary::after {
            content: "+"; font-size: 1.5rem; font-weight: 300; color: var(--text-tertiary);
        }
        details.accordion[open] summary::after { content: "-"; }
        details.accordion[open] summary { border-bottom: 1px solid var(--border-light); }
        .accordion-content { padding: 1.5rem; background: #fff; }

        /* VISUALIZATION: CHARTS (SVG) */
        .chart-container {
            position: relative;
            height: 250px;
            width: 100%;
            margin: 2rem 0;
            background: #fff;
            border-radius: var(--radius-md);
            border: 1px solid var(--border-light);
            padding: 1rem;
        }
        svg.chart { width: 100%; height: 100%; overflow: visible; }
        .chart-line { fill: none; stroke: var(--color-blue); stroke-width: 2.5; stroke-linecap: round; stroke-linejoin: round; }
        .chart-line.secondary { stroke: var(--color-red); }
        .chart-axis { stroke: var(--border-light); stroke-width: 1; }
        .chart-text { font-size: 10px; fill: var(--text-tertiary); font-family: var(--font-stack); }
        .chart-tooltip { fill: var(--text-primary); font-size: 12px; font-weight: bold; }

        /* SCENARIO VISUALIZATION (Before/After) */
        .scenario-box {
            display: flex;
            gap: 1rem;
            align-items: center;
            margin: 1rem 0;
            flex-wrap: wrap;
        }
        .scenario-card {
            flex: 1;
            background: #fff;
            border: 1px solid var(--border-light);
            border-radius: var(--radius-sm);
            padding: 1rem;
            min-width: 200px;
        }
        .scenario-arrow { color: var(--text-tertiary); font-size: 1.5rem; }
        .scenario-label { font-size: 0.8rem; color: var(--text-tertiary); margin-bottom: 4px; }
        .scenario-val { font-size: 1.1rem; font-weight: 700; color: var(--text-primary); }
        .scenario-change { font-size: 0.8rem; margin-top: 4px; font-weight: 600; }
        .col-red { color: var(--color-red); }
        .col-blue { color: var(--color-blue); }

        /* RESPONSIVE */
        @media (max-width: 900px) {
            .app-container { flex-direction: column; }
            .sidebar { width: 100%; height: auto; position: static; border-right: none; border-bottom: 1px solid var(--border-light); padding: 1rem; }
            .main-content { padding: 2rem 1.5rem; }
            h1 { font-size: 2rem; }
        }
    

        

        
        
        

        .container {
            max-width: 900px;
            margin: 4rem auto;
            padding: 0 2rem;
        }

        header {
            text-align: center;
            margin-bottom: 3rem;
        }

        h1 {
            font-size: 2.5rem;
            font-weight: 800;
            letter-spacing: -1px;
            margin-bottom: 0.5rem;
        }

        .subtitle {
            font-size: 1.1rem;
            color: var(--text-secondary);
        }

        .lecture-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
            gap: 1.5rem;
        }

        .lecture-card {
            background: var(--bg-card);
            border-radius: var(--radius-md);
            padding: 2rem;
            box-shadow: var(--shadow-card);
            border: 1px solid var(--border-light);
            transition: transform 0.2s, box-shadow 0.2s;
            display: flex;
            flex-direction: column;
            text-decoration: none;
            color: inherit;
        }

        .lecture-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.08);
            border-color: var(--color-blue);
        }

        .card-badge {
            display: inline-block;
            background: rgba(49, 130, 246, 0.1);
            color: var(--color-blue);
            font-size: 0.75rem;
            font-weight: 700;
            padding: 4px 10px;
            border-radius: 20px;
            margin-bottom: 1rem;
            align-self: flex-start;
        }
        
        .card-badge.badge-soon {
            background: #f2f4f6;
            color: var(--text-secondary);
        }

        .lecture-title {
            font-size: 1.4rem;
            font-weight: 700;
            margin-bottom: 0.8rem;
            line-height: 1.3;
        }

        .lecture-desc {
            color: var(--text-secondary);
            font-size: 0.95rem;
            flex-grow: 1;
        }

        .lecture-footer {
            margin-top: 1.5rem;
            padding-top: 1.5rem;
            border-top: 1px solid var(--border-light);
            font-size: 0.85rem;
            color: var(--color-blue);
            font-weight: 600;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .lecture-footer span.arrow {
            transition: transform 0.2s;
        }

        .lecture-card:hover .lecture-footer span.arrow {
            transform: translateX(4px);
        }

    
/* Transitions */
.fade-enter-active, .fade-leave-active { transition: opacity 0.3s ease; }

